#include <WiFi.h>
#include <WebServer.h>

#define light_sensor_analog 32
#define relay 26

const char* ssid = "thay Long dep trai";
const char* password = "12345678";

WebServer server(80);

// Trạng thái hệ thống
bool relayState = false;
bool autoMode = true;

// ================= WEB =================
void handleRoot() {
  String html = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
    <title>ESP32 Light Control</title>
    <script>
        function updateData() {
            fetch("/value")
            .then(r => r.text())
            .then(data => {
                document.getElementById("lightValue").innerHTML = data;
            });

            fetch("/state")
            .then(r => r.text())
            .then(data => {
                document.getElementById("relayState").innerHTML = data;
            });

            fetch("/mode")
            .then(r => r.text())
            .then(data => {
                document.getElementById("mode").innerHTML = data;
            });
        }

        function toggleRelay() {
            fetch("/toggle");
        }

        function changeMode() {
            fetch("/setmode");
        }

        setInterval(updateData, 500);
    </script>
</head>
<body>
    <h1>ESP32 Light Control</h1>

    <h2>Light: <span id="lightValue">0</span></h2>
    <h2>Relay: <span id="relayState">OFF</span></h2>
    <h2>Mode: <span id="mode">AUTO</span></h2>

    <button onclick="toggleRelay()">Toggle Relay</button>
    <button onclick="changeMode()">Auto / Manual</button>

</body>
</html>
)rawliteral";

  server.send(200, "text/html", html);
}

// ================= API =================
void handleValue() {
  int val = analogRead(light_sensor_analog);
  server.send(200, "text/plain", String(val));
}

void handleState() {
  server.send(200, "text/plain", relayState ? "ON" : "OFF");
}

void handleMode() {
  server.send(200, "text/plain", autoMode ? "AUTO" : "MANUAL");
}

void handleToggle() {
  if (!autoMode) {
    relayState = !relayState;
    digitalWrite(relay, relayState);
  }
  server.send(200, "text/plain", "OK");
}

void handleSetMode() {
  autoMode = !autoMode;
  server.send(200, "text/plain", "OK");
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);

  pinMode(relay, OUTPUT);
  digitalWrite(relay, LOW);

  analogSetPinAttenuation(light_sensor_analog, ADC_11db);

  WiFi.softAP(ssid, password);

  Serial.print("IP Address: ");
  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.on("/value", handleValue);
  server.on("/state", handleState);
  server.on("/mode", handleMode);
  server.on("/toggle", handleToggle);
  server.on("/setmode", handleSetMode);

  server.begin();
}

// ================= LOOP =================
void loop() {
  server.handleClient();

  int light_value = analogRead(light_sensor_analog);

  if (autoMode) {
    if (light_value > 1000) {
      relayState = true;
    } else {
      relayState = false;
    }
    digitalWrite(relay, relayState);
  }
}
