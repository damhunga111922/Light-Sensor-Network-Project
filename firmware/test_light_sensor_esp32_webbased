#include <WiFi.h>
#include <WebServer.h>

#define light_sensor_analog 32   // DÙNG ADC1 (không dùng 2 nữa)

const char* ssid = "ESP32_light";
const char* password = "12345678";

WebServer server(80);

// Trang chính
void handleRoot() {
  String html = R"rawliteral(
  <!DOCTYPE html>
  <html>
  <head>
      <title>ESP32 Light Sensor</title>
      <script>
          function updateValue() {
              fetch("/value")
              .then(response => response.text())
              .then(data => {
                  document.getElementById("lightValue").innerHTML = data;
              });
          }
          setInterval(updateValue, 500);
      </script>
  </head>
  <body>
      <h1>Light Sensor Monitor</h1>
      <h2>Analog value: <span id="lightValue">0</span></h2>
  </body>
  </html>
  )rawliteral";

  server.send(200, "text/html", html);
}

// API trả về giá trị cảm biến
void handleValue() {
  int light_analog_value = analogRead(light_sensor_analog);
  server.send(200, "text/plain", String(light_analog_value));
}

void setup() {
  Serial.begin(115200);

  analogSetPinAttenuation(light_sensor_analog, ADC_11db);

  // Phát WiFi
  WiFi.softAP(ssid, password);

  Serial.print("IP Address: ");
  Serial.println(WiFi.softAPIP());

  // Định tuyến web
  server.on("/", handleRoot);
  server.on("/value", handleValue);

  server.begin();
}

void loop() {
  server.handleClient();
}
